{
  "type": "object",
  "required": [
    "data",
    "meta"
  ],
  "properties": {
    "data": {
      "type": "object",
      "required": [
        "investmentType",
        "remuneration",
        "issueUnitPrice",
        "issueDate",
        "dueDate",
        "voucherPaymentIndicator",
        "purchaseDate",
        "taxExemptProduct"
      ],
      "properties": {
        "issuerInstitutionCnpjNumber": {
          "type": "string",
          "description": "CNPJ da instituição emissora.\n\nCaso a instituição tenha a informação, o envio será obrigatório.",
          "maxLength": 14,
          "pattern": "^[0-9A-Z]{12}[0-9]{2}$",
          "example": "11225860000140"
        },
        "isinCode": {
          "type": "string",
          "description": "Código ISIN é um código universal que identifica cada valor mobiliário ou instrumento financeiro, conforme Norma ISO 6166.\n\n[Restrição] Deve ser preenchido nos casos em que o 'clearingCode' não seja preenchido.",
          "maxLength": 12,
          "pattern": "^[A-Z]{2}([A-Z0-9]){9}\\d{1}$",
          "example": "BRCST4CTF001"
        },
        "investmentType": {
          "type": "string",
          "description": "Especificação do ativo em questão (Debêntures, CRI ou CRA).",
          "enum": [
            "DEBENTURES",
            "CRI",
            "CRA"
          ],
          "example": "CRI"
        },
        "debtorCnpjNumber": {
          "type": "string",
          "description": "CNPJ do devedor. Caso a transmissora possua a informação para os produtos CRI e CRA, o envio deste campo é obrigatório.",
          "maxLength": 14,
          "pattern": "^[0-9A-Z]{12}[0-9]{2}$",
          "example": "11225860000140"
        },
        "debtorName": {
          "type": "string",
          "description": "Nome do devedor. Caso a transmissora possua a informação para os produtos CRI e CRA, o envio deste campo é obrigatório.",
          "pattern": "[\\w\\W\\s]*",
          "maxLength": 70,
          "example": "Roberto Marino"
        },
        "taxExemptProduct": {
          "type": "string",
          "description": "Indicador de um produto incentivado",
          "enum": [
            "SIM",
            "NAO"
          ],
          "example": "SIM"
        },
        "remuneration": {
          "type": "object",
          "required": [
            "indexer"
          ],
          "properties": {
            "preFixedRate": {
              "type": "string",
              "description": "Valor da taxa de emissão do contrato.\n[Restrição] Campo de preenchimento obrigatório quando houver 'PRE_FIXADO' no campo 'indexer' ou quando se tratar de produto híbrido.",
              "maxLength": 9,
              "pattern": "^-?\\d{1}\\.\\d{6}$",
              "example": "0.300000"
            },
            "postFixedIndexerPercentage": {
              "type": "string",
              "description": "Percentual do indexador de emissão do contrato.\n[Restrição] Campo de preenchimento obrigatório quando o campo 'indexer' for diferente de 'PRE_FIXADO' ou produto híbrido.",
              "maxLength": 9,
              "pattern": "^-?\\d{1}\\.\\d{6}$",
              "example": "1.100000"
            },
            "rateType": {
              "type": "string",
              "description": "Tipo da taxa de remuneração.",
              "enum": [
                "LINEAR",
                "EXPONENCIAL"
              ],
              "example": "LINEAR"
            },
            "ratePeriodicity": {
              "type": "string",
              "description": "Periodicidade da taxa de remuneração (mensal, anual, diário, semestral).",
              "enum": [
                "MENSAL",
                "ANUAL",
                "DIARIO",
                "SEMESTRAL"
              ],
              "example": "MENSAL"
            },
            "calculation": {
              "type": "string",
              "description": "Base de cálculo (dias úteis ou dias corridos).",
              "enum": [
                "DIAS_UTEIS",
                "DIAS_CORRIDOS"
              ],
              "example": "DIAS_CORRIDOS"
            },
            "indexer": {
              "type": "string",
              "description": "Índice utilizado como referência para a correção da rentabilidade e/ou rendimentos do ativo.",
              "enum": [
                "CDI",
                "DI",
                "TR",
                "IPCA",
                "IGP_M",
                "IGP_DI",
                "INPC",
                "BCP",
                "TLC",
                "SELIC",
                "PRE_FIXADO",
                "OUTROS"
              ],
              "example": "CDI"
            },
            "indexerAdditionalInfo": {
              "type": "string",
              "description": "Informações adicionais do indexador.\n[Restrição] Obrigatório quando houver 'OUTROS' no campo 'indexer'.",
              "pattern": "[\\w\\W\\s]*",
              "maxLength": 50,
              "example": "Dólar"
            }
          }
        },
        "issueUnitPrice": {
          "type": "object",
          "required": [
            "amount",
            "currency"
          ],
          "properties": {
            "amount": {
              "type": "string",
              "description": "Valor relacionado ao objeto.",
              "maxLength": 24,
              "pattern": "^\\d{1,15}\\.\\d{2,8}$",
              "example": "1000.000004"
            },
            "currency": {
              "type": "string",
              "description": "Moeda referente ao valor monetário, seguindo o modelo ISO-4217.",
              "maxLength": 3,
              "pattern": "^[A-Z]{3}$",
              "example": "BRL"
            }
          }
        },
        "issueDate": {
          "type": "string",
          "format": "date",
          "description": "Data de emissão do título",
          "maxLength": 10,
          "pattern": "^(\\d{4})-(1[0-2]|0?[1-9])-(3[01]|[12][0-9]|0?[1-9])$",
          "example": "2018-02-16"
        },
        "dueDate": {
          "type": "string",
          "format": "date",
          "description": "Data de vencimento do título",
          "maxLength": 10,
          "pattern": "^(\\d{4})-(1[0-2]|0?[1-9])-(3[01]|[12][0-9]|0?[1-9])$",
          "example": "2018-02-15"
        },
        "voucherPaymentIndicator": {
          "type": "string",
          "description": "Indicativo se há pagamento de cupom",
          "enum": [
            "SIM",
            "NAO"
          ],
          "example": "SIM"
        },
        "voucherPaymentPeriodicity": {
          "type": "string",
          "description": "Periodicidade de pagamento de cupom.",
          "enum": [
            "MENSAL",
            "TRIMESTRAL",
            "SEMESTRAL",
            "ANUAL",
            "IRREGULAR",
            "OUTROS"
          ],
          "example": "MENSAL"
        },
        "voucherPaymentPeriodicityAdditionalInfo": {
          "type": "string",
          "description": "Informações adicionais da periodicidade de pagamento de cupom.",
          "maxLength": 50,
          "pattern": "[\\w\\W\\s]*",
          "example": "Diária"
        },
        "clearingCode": {
          "type": "string",
          "description": "Código de registro do ativo na Clearing.\n[Restrição] Deve ser preenchido nos casos em que o 'isinCode' não seja preenchido.",
          "maxLength": 30,
          "pattern": "[\\w\\W-]*",
          "example": "CDB421GPXXX"
        },
        "purchaseDate": {
          "type": "string",
          "format": "date",
          "description": "Data de aquisição do cliente",
          "maxLength": 10,
          "pattern": "^(\\d{4})-(1[0-2]|0?[1-9])-(3[01]|[12][0-9]|0?[1-9])$",
          "example": "2018-02-15"
        },
        "gracePeriodDate": {
          "type": "string",
          "format": "date",
          "description": "Data até a qual o cliente não poderá resgatar antecipadamente seu investimento.",
          "maxLength": 10,
          "pattern": "^(\\d{4})-(1[0-2]|0?[1-9])-(3[01]|[12][0-9]|0?[1-9])$",
          "example": "2018-02-16"
        }
      }
    },
    "meta": {
      "type": "object",
      "description": "Meta informações referente a API requisitada.",
      "required": [
        "totalRecords",
        "totalPages",
        "requestDateTime"
      ],
      "properties": {
        "totalRecords": {
          "type": "integer",
          "format": "int32",
          "description": "Número total de registros no resultado",
          "example": 1
        },
        "totalPages": {
          "type": "integer",
          "format": "int32",
          "description": "Número total de páginas no resultado",
          "example": 1
        },
        "requestDateTime": {
          "type": "string",
          "format": "date-time",
          "maxLength": 20,
          "description": "Data e hora da consulta, conforme especificação RFC-3339, formato UTC.",
          "example": "2021-05-21T08:30:00Z"
        }
      }
    }
  }
}
