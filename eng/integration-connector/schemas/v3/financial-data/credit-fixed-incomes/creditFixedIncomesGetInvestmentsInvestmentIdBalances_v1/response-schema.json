{
  "type": "object",
  "required": [
    "data",
    "meta"
  ],
  "properties": {
    "data": {
      "type": "object",
      "required": [
        "referenceDateTime",
        "updatedUnitPrice",
        "quantity",
        "grossAmount",
        "netAmount",
        "incomeTax",
        "financialTransactionTax",
        "blockedBalance",
        "purchaseUnitPrice"
      ],
      "properties": {
        "referenceDateTime": {
          "type": "string",
          "format": "date-time",
          "description": "Data e hora da última posição consolidada disponível a que se referem os dados transacionais do cliente disponíveis nos canais eletrônicos. Na representação deve considerar minutos e segundos como zero (00:00:00Z).",
          "maxLength": 20,
          "pattern": "(^(\\d{4})-(1[0-2]|0?[1-9])-(3[01]|[12][0-9]|0?[1-9])T(?:[01]\\d|2[0123]):(?:[012345]\\d):(?:[012345]\\d)Z$)",
          "example": "2022-07-21T17:32:00Z"
        },
        "updatedUnitPrice": {
          "type": "object",
          "description": "Valor bruto unitário atualizado na data de referência.",
          "required": [
            "amount",
            "currency"
          ],
          "properties": {
            "amount": {
              "type": "string",
              "pattern": "^\\d{1,15}\\.\\d{2,8}$",
              "maxLength": 24,
              "minLength": 4,
              "example": "1000.0400",
              "description": "Valor relacionado ao objeto."
            },
            "currency": {
              "type": "string",
              "description": "Moeda referente ao valor monetário, seguindo o modelo ISO-4217.",
              "maxLength": 3,
              "pattern": "^[A-Z]{3}$",
              "example": "BRL"
            }
          }
        },
        "quantity": {
          "type": "string",
          "description": "Quantidade de títulos detidos na data da posição do cliente.",
          "maxLength": 24,
          "minLength": 4,
          "pattern": "^\\d{1,15}\\.\\d{2,8}$",
          "example": "15.00"
        },
        "grossAmount": {
          "type": "object",
          "description": "Valor do investimento que se refere a quantidade x PU atualizado na data de referência.",
          "required": [
            "amount",
            "currency"
          ],
          "properties": {
            "amount": {
              "type": "string",
              "pattern": "^\\d{1,15}\\.\\d{2,4}$",
              "maxLength": 20,
              "minLength": 4,
              "example": "1000.04",
              "description": "Valor relacionado ao objeto."
            },
            "currency": {
              "type": "string",
              "maxLength": 3,
              "pattern": "^[A-Z]{3}$",
              "example": "BRL",
              "description": "Moeda referente ao valor monetário, seguindo o modelo ISO-4217."
            }
          }
        },
        "netAmount": {
          "type": "object",
          "description": "Valor do investimento atualizado na data de referência, posterior à dedução de impostos (IOF e IR).",
          "required": [
            "amount",
            "currency"
          ],
          "properties": {
            "amount": {
              "type": "string",
              "pattern": "^\\d{1,15}\\.\\d{2,4}$",
              "maxLength": 20,
              "minLength": 4,
              "example": "1000.04",
              "description": "Valor relacionado ao objeto."
            },
            "currency": {
              "type": "string",
              "maxLength": 3,
              "pattern": "^[A-Z]{3}$",
              "example": "BRL",
              "description": "Moeda referente ao valor monetário, seguindo o modelo ISO-4217."
            }
          }
        },
        "incomeTax": {
          "type": "object",
          "description": "Valor do imposto de renda provisionado considerando a alíquota vigente na data de referência.",
          "required": [
            "amount",
            "currency"
          ],
          "properties": {
            "amount": {
              "type": "string",
              "pattern": "^\\d{1,15}\\.\\d{2,4}$",
              "maxLength": 20,
              "minLength": 4,
              "example": "1000.04",
              "description": "Valor relacionado ao objeto."
            },
            "currency": {
              "type": "string",
              "maxLength": 3,
              "pattern": "^[A-Z]{3}$",
              "example": "BRL",
              "description": "Moeda referente ao valor monetário, seguindo o modelo ISO-4217."
            }
          }
        },
        "financialTransactionTax": {
          "type": "object",
          "description": "Valor do IOF provisionado considerando a alíquota vigente na data de referência.",
          "required": [
            "amount",
            "currency"
          ],
          "properties": {
            "amount": {
              "type": "string",
              "pattern": "^\\d{1,15}\\.\\d{2,4}$",
              "maxLength": 20,
              "minLength": 4,
              "example": "1000.04",
              "description": "Valor relacionado ao objeto."
            },
            "currency": {
              "type": "string",
              "maxLength": 3,
              "pattern": "^[A-Z]{3}$",
              "example": "BRL",
              "description": "Moeda referente ao valor monetário, seguindo o modelo ISO-4217."
            }
          }
        },
        "blockedBalance": {
          "type": "object",
          "description": "Valor não disponível para movimentação naquele momento por qualquer motivo (bloqueio judicial, bloqueio em garantia, entre outros).",
          "required": [
            "amount",
            "currency"
          ],
          "properties": {
            "amount": {
              "type": "string",
              "pattern": "^\\d{1,15}\\.\\d{2,4}$",
              "maxLength": 20,
              "minLength": 4,
              "example": "1000.04",
              "description": "Valor relacionado ao objeto."
            },
            "currency": {
              "type": "string",
              "maxLength": 3,
              "pattern": "^[A-Z]{3}$",
              "example": "BRL",
              "description": "Moeda referente ao valor monetário, seguindo o modelo ISO-4217."
            }
          }
        },
        "purchaseUnitPrice": {
          "type": "object",
          "description": "Valor unitário negociado com o cliente na data de aquisição.",
          "required": [
            "amount",
            "currency"
          ],
          "properties": {
            "amount": {
              "type": "string",
              "pattern": "^\\d{1,15}\\.\\d{2,8}$",
              "maxLength": 24,
              "minLength": 4,
              "example": "1000.000004",
              "description": "Valor relacionado ao objeto."
            },
            "currency": {
              "type": "string",
              "maxLength": 3,
              "pattern": "^[A-Z]{3}$",
              "example": "BRL",
              "description": "Moeda referente ao valor monetário, seguindo o modelo ISO-4217."
            }
          }
        },
        "preFixedRate": {
          "type": "string",
          "description": "Taxa de remuneração acordada com o cliente na contratação.",
          "maxLength": 9,
          "minLength": 8,
          "pattern": "^-?\\d{1}\\.\\d{6}$",
          "example": "0.300000"
        },
        "postFixedIndexerPercentage": {
          "type": "string",
          "description": "Percentual do indexador acordado com o cliente na contratação.",
          "maxLength": 9,
          "minLength": 8,
          "pattern": "^-?\\d{1}\\.\\d{6}$",
          "example": "1.100000"
        },
        "fine": {
          "type": "object",
          "description": "Valor de multa devido ao atraso do pagamento acordado em contrato.",
          "required": [
            "amount",
            "currency"
          ],
          "properties": {
            "amount": {
              "type": "string",
              "pattern": "^\\d{1,15}\\.\\d{2,4}$",
              "maxLength": 20,
              "minLength": 4,
              "example": "1000.04"
            },
            "currency": {
              "type": "string",
              "pattern": "^[A-Z]{3}$",
              "maxLength": 3,
              "example": "BRL"
            }
          }
        },
        "latePayment": {
          "type": "object",
          "description": "Valor de mora devido ao atraso do pagamento acordado em contrato.",
          "required": [
            "amount",
            "currency"
          ],
          "properties": {
            "amount": {
              "type": "string",
              "pattern": "^\\d{1,15}\\.\\d{2,4}$",
              "maxLength": 20,
              "minLength": 4,
              "example": "1000.04"
            },
            "currency": {
              "type": "string",
              "pattern": "^[A-Z]{3}$",
              "maxLength": 3,
              "example": "BRL"
            }
          }
        }
      }
    },
    "meta": {
      "type": "object",
      "description": "Meta informações referente a API requisitada.",
      "required": [
        "totalRecords",
        "totalPages",
        "requestDateTime"
      ],
      "properties": {
        "totalRecords": {
          "type": "integer",
          "format": "int32",
          "example": 1
        },
        "totalPages": {
          "type": "integer",
          "format": "int32",
          "example": 1
        },
        "requestDateTime": {
          "type": "string",
          "format": "date-time",
          "maxLength": 20,
          "example": "2021-05-21T08:30:00Z"
        }
      }
    }
  }
}
